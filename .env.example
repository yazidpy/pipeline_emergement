# --- PostgreSQL (identifiants base ; utilisés aussi par le conteneur postgres) ---
POSTGRES_DB=emargement
POSTGRES_USER=emargement
POSTGRES_PASSWORD=emargement

# Port exposé sur ta machine (doit correspondre à POSTGRES_PORT ci-dessous pour les scripts locaux)
POSTGRES_PUBLISH_PORT=5433

# Depuis Windows/Mac : lance generate.py avec l’hôte loopback + ce port (pas "postgres").
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

# --- Airflow (toujours @postgres:5432 : nom de service sur le réseau Docker) ---
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://emargement:emargement@postgres:5432/emargement
AIRFLOW__CORE__FERNET_KEY=please-generate-a-fernet-key
AIRFLOW__WEBSERVER__SECRET_KEY=please-set-a-random-secret
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=true
AIRFLOW__CORE__LOAD_EXAMPLES=false

# --- Spark ---
SPARK_MASTER_URL=spark://spark-master:7077

# --- Pipeline ---
ABSENCES_SEUIL_CONSECUTIF=3

# --- Logging ---
LOG_LEVEL=INFO
